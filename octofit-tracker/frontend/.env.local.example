# Environment configuration for OctoFit Tracker frontend
# Copy this file to .env.local and fill in the values

# GitHub Codespace name - REQUIRED for production use
# This is used to construct API URLs like: https://{VITE_CODESPACE_NAME}-8000.app.github.dev
# If not set, the app will fall back to http://localhost:8000 (development)
# Example: VITE_CODESPACE_NAME=mycodespace
VITE_CODESPACE_NAME=
